# Mapbox — public token for the map (must start with pk.)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: Mapbox secret for server-side geocoding (sk.) — never expose as NEXT_PUBLIC_
MAPBOX_SECRET_TOKEN=

# Supabase — optional; without these, submissions use local/demo data only
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
