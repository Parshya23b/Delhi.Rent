# Mapbox — public token for the map (must start with pk.)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: Mapbox secret for server-side geocoding (sk.) — never expose as NEXT_PUBLIC_
MAPBOX_SECRET_TOKEN=

# Supabase — URL + anon key is enough for map / leaderboard reads (RLS allows select on rent_entries).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server only): required for inserts, confirms, reports, bans — never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URI (Supabase → Settings → Database → Connection string → URI).
# Used by scripts/apply-sql-file.mjs and db:verify:* seeker RPC scripts (not required for Next.js map-only).
# DATABASE_URL=
